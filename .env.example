# Postgres connection string (used by Diesel + diesel-async)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/agent_rs_web

# gRPC endpoint for agent-service (default: http://localhost:1072)
AGENT_RS_GRPC_URL=http://localhost:1072

# Secret key for signing session cookies (at least 64 random bytes, base64- or hex-encoded)
SESSION_SECRET=change-me-to-a-long-random-string-before-production
