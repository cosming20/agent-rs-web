# Local dev defaults. Copy to `.env` (git-ignored) and override as needed.

# ----------------------------------------------------------------------------
# agent-rs-web local infra (docker-compose)
# ----------------------------------------------------------------------------
AGENT_RS_WEB_POSTGRES_PORT=1055
AGENT_RS_WEB_POSTGRES_USER=webapp
AGENT_RS_WEB_POSTGRES_PASSWORD=changeme-web
AGENT_RS_WEB_POSTGRES_DB=agent_rs_web

AGENT_RS_WEB_REDIS_PORT=1074

# ----------------------------------------------------------------------------
# Connection strings read by the server binary (main.rs)
# ----------------------------------------------------------------------------
# Postgres: users table + (future) persistent session metadata.
DATABASE_URL=postgres://webapp:changeme-web@localhost:1055/agent_rs_web

# Redis: tower-sessions session store (replaces MemoryStore — sessions
# now survive server restarts).
REDIS_URL=redis://localhost:1074

# Secret key for session cookies (at least 64 random bytes; generate via
# `openssl rand -hex 64` or `head -c 64 /dev/urandom | base64`).
SESSION_SECRET=change-me-to-a-long-random-string-before-production

# ----------------------------------------------------------------------------
# Upstream agent gRPC endpoint (agent-rs-agent-service)
# ----------------------------------------------------------------------------
AGENT_RS_GRPC_URL=http://localhost:1072

# ----------------------------------------------------------------------------
# Logging
# ----------------------------------------------------------------------------
RUST_LOG=info,agent_rs_web=debug
